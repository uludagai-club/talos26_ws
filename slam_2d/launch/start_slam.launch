<launch>
    <!-- Use simulation time -->
    <param name="/use_sim_time" value="true"/>

    <!-- 1. Start the Simulation (Gazebo + Robot Model) -->
    <include file="$(find cart_sim)/launch/cart_sim.launch">
        <arg name="launch_tf" value="false"/>
        <arg name="rviz" value="false"/>
    </include>

    <!-- 2. Ground Truth TF Broadcaster -->
    <node pkg="slam_2d" type="gt_tf_broadcaster.py" name="gt_tf_broadcaster" output="screen" />

    <!-- 3. PointCloud to LaserScan -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/cart/center_laser/scan"/>
        <remap from="scan" to="/scan"/>
        
        <!-- Use planar laser_2d frame to satisfy gmapping's planar laser requirement -->
        <param name="target_frame" value="laser_2d"/>
        <param name="transform_tolerance" value="0.5"/>
        <param name="min_height" value="-0.5"/>
        <param name="max_height" value="1.0"/>
        <param name="angle_min" value="-3.14159"/>
        <param name="angle_max" value="3.14159"/>
        <param name="angle_increment" value="0.0087"/>
        <param name="scan_time" value="0.1"/>
        <param name="range_min" value="0.5"/>
        <param name="range_max" value="30.0"/>
        <param name="use_inf" value="false"/>
        <param name="inf_epsilon" value="1.0"/>
        <param name="concurrency_level" value="1"/>
    </node>

    <!-- 4. GMapping SLAM -->
    <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
        <!-- TF Frames -->
        <param name="odom_frame" value="world"/>
        <param name="base_frame" value="chassis"/>
        <param name="map_frame" value="map"/>
        
        <!-- Scan Topic -->
        <param name="scan" value="/scan"/>
        
        <!-- Map Parameters -->
        <param name="map_update_interval" value="1.0"/>
        <param name="maxUrange" value="25.0"/>
        <param name="maxRange" value="30.0"/>
        
        <!-- Motion Model Parameters -->
        <!-- Set minimumScore very high to force using odometry (GT) instead of scan matching result -->
        <param name="minimumScore" value="10000"/>
        <param name="linearUpdate" value="0.2"/>
        <param name="angularUpdate" value="0.1"/>
        <param name="temporalUpdate" value="1.0"/>
        <param name="resampleThreshold" value="0.5"/>
        
        <!-- Grid Parameters -->
        <param name="xmin" value="-50.0"/>
        <param name="ymin" value="-50.0"/>
        <param name="xmax" value="50.0"/>
        <param name="ymax" value="50.0"/>
        <param name="delta" value="0.05"/>
        
        <!-- Particle Filter - Single particle for deterministic GT mapping -->
        <param name="particles" value="1"/>
        
        <!-- Occupancy Grid Thresholds -->
        <param name="occ_thresh" value="0.25"/>
        <param name="lstep" value="0.05"/>
        <param name="astep" value="0.05"/>
        <param name="iterations" value="5"/>
        <param name="lsigma" value="0.075"/>
        <param name="ogain" value="3.0"/>
        <param name="lskip" value="0"/>
        
        <!-- Trust Odometry (GT) completely - Zero noise -->
        <param name="srr" value="0.0"/>
        <param name="srt" value="0.0"/>
        <param name="str" value="0.0"/>
        <param name="stt" value="0.0"/>
        
        <!-- Transform publish settings - we use GT so disable -->
        <param name="transform_publish_period" value="0.0"/>
    </node>

    <!-- 5. RViz with SLAM config -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find slam_2d)/rviz/slam_2d.rviz" output="screen"/>

</launch>
