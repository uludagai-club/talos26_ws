<?xml version="1.0"?>
<launch>

  <arg name="world_name" default="$(find cart_sim)/worlds/engelli_sim.world" />
  <arg name="use_sim_time" default="true" />
  <arg name="rvizconfig" default="$(find cart_sim)/rviz/cart.rviz" />
  <arg name="spawn_car" default="true" />
  <arg name="launch_tf" default="true" />

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="verbose" value="true"/>
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="paused" value="true" />
    <arg name="headless" value="false"/>
  </include>
  
  <param name="robot_description" command="cat $(find cart_sim)/urdf/golf.urdf" />
  
  <node name="spawn_senaryo2" pkg="gazebo_ros" type="spawn_model" args="-file $(find cart_sim)/models/senaryo2/model.sdf -sdf -x 1 -y 1 -z 0 -Y -0.016072 -model senaryo2" output="screen"/>

  <node if="$(arg spawn_car)" name="spawn_car" pkg="gazebo_ros" type="spawn_model" args="-urdf -param robot_description -x -14.935761 -y -34.031181 -z 0.4 -Y -0.016072 -model golf" output="screen" respawn="false"/>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" >
    </node>

  <node pkg="cart_sim" type="odom_tf_broadcaster.py" name="odom_tf_broadcaster" output="screen" />

  <node pkg="cart_sim" type="fix_gazebo_cloud.py" name="gazebo_cloud_fixer" output="screen" />

  <node if="$(arg launch_tf)" pkg="fake_localization" type="fake_localization" name="fake_localization">
    </node>
  
  <node name="cloud_transformer" pkg="cart_sim" type="cloud_transformer" respawn="false"/>

  <node pkg="cart_sim" type="controller" name="controller"/>

  <arg name="rviz" default="true"/>
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="$(anon rviz)" respawn="false" output="screen" args="-d $(find cart_sim)/rviz/cart.rviz" />

</launch>
